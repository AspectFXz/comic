                        if (entry.isIntersecting) {
                            entry.target.classList.add('in-view');
                            observer.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });
                sections.forEach(function(el) { observer.observe(el); });
            })();

            // Cost calculator
            (function() {
                var slider = document.getElementById('calcScenesSlider');
                var imgModel = document.getElementById('calcImageModel');
                var vidModel = document.getElementById('calcVideoModel');
                if (!slider) return;

                var PRICE_PER_CREDIT = 27.99 / 750;

                function getSelected(container) {
                    var sel = container.querySelector('.calc-tab.active');
                    return sel ? parseInt(sel.getAttribute('data-credits'), 10) : 1;
                }

                function update() {
                    var scenes = parseInt(slider.value, 10);
                    var imgCr = getSelected(imgModel);
                    var vidCr = getSelected(vidModel);
                    var total = scenes * (imgCr + vidCr);
                    var price = total * PRICE_PER_CREDIT;

                    document.getElementById('calcScenesValue').textContent = scenes;
                    document.getElementById('calcPriceDollar').textContent = '$' + price.toFixed(2);
                    document.getElementById('calcPriceCredits').textContent = total + ' credits';
                }

                slider.addEventListener('input', update);

                [imgModel, vidModel].forEach(function(container) {
                    container.addEventListener('click', function(e) {
                        var tab = e.target.closest('.calc-tab');
                        if (!tab) return;
                        container.querySelectorAll('.calc-tab').forEach(function(t) { t.classList.remove('active'); });
                        tab.classList.add('active');
                        update();
                    });
                });

                update();
            })();

            // Showcase cards are now <a> links — no video JS needed

            // Video modal
            function openVideoModal(src) {
                var modal = document.getElementById('videoModal');
                var player = document.getElementById('videoModalPlayer');
                player.src = src;
                modal.style.display = 'flex';
            }
            function closeVideoModal(e) {
                var modal = document.getElementById('videoModal');
                var player = document.getElementById('videoModalPlayer');
                player.pause();
                player.src = '';
                modal.style.display = 'none';
            }
        </script>
    </body>
</html>
