        <!-- Prompt Generator CSS — copied verbatim for 1:1 UI match -->
        <style>
            html {
                font-size: 14px;
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: "DM Sans", "Inter", sans-serif !important;
                background-color: #000000 !important;
                background-image: none !important;
                color: #ffffff;
                min-height: 100vh;
                line-height: 1.6;
            }

            a {
                color: rgb(0, 115, 255);
                text-decoration: none;
            }

            /* Navbar */
            .navbar {
                position: fixed;
                top: 20px;
                left: 50%;
                transform: translateX(-50%);
                background: rgba(8, 8, 8, 0.2);
                backdrop-filter: blur(10px);
                -webkit-backdrop-filter: blur(10px);
                padding: 16px 24px;
                z-index: 1000;
                width: 90%;
                max-width: 1200px;
                border-radius: 100px;
                border: 1px solid rgba(255, 255, 255, 0.1);
            }
            .nav-container {
                display: grid;
                grid-template-columns: 1fr auto 1fr;
                align-items: center;
                padding: 0;
                margin: 0;
                width: 100%;
            }
            .logo {
                font-size: 24px;
                font-weight: 500;
                color: white;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 8px;
            }
            .logo img {
                width: 28px;
                height: 28px;
                object-fit: contain;
            }
            .nav-links {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 40px;
            }
            .nav-links a {
                color: rgba(255, 255, 255, 0.7);
                text-decoration: none;
                font-size: 15px;
                font-weight: 500;
                transition: color 0.2s ease;
                padding: 8px 0;
            }
            .nav-links a:hover {
                color: white;
            }
            .auth-buttons {
                display: flex;
                align-items: center;
                justify-content: flex-end;
            }
            .get-started-btn {
                background: rgb(0, 115, 255);
                color: #fff;
                padding: 16px 36px;
                border-radius: 100px;
                text-decoration: none;
                font-size: 17px;
                font-weight: 500;
                transition: all 0.2s ease;
                border: none;
                box-shadow:
                    0 0 20px rgba(0, 115, 255, 0.3),
                    0 0 40px rgba(0, 115, 255, 0.1),
                    inset 0 0 0 1px rgba(255, 255, 255, 0.2);
                text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
                letter-spacing: 0.3px;
            }
            .get-started-btn:hover {
                transform: translateY(-1px);
                background: rgb(30, 130, 255);
                box-shadow:
                    0 0 30px rgba(0, 115, 255, 0.4),
                    0 0 60px rgba(0, 115, 255, 0.2),
                    inset 0 0 0 1px rgba(255, 255, 255, 0.3);
            }
            @media (max-width: 768px) {
                .navbar {
                    top: 12px;
                    padding: 12px 20px;
                    width: calc(100% - 24px);
                }
                .nav-container {
                    padding: 0;
                }
                .nav-links {
                    display: none;
                }
                .get-started-btn {
                    padding: 12px 28px;
                    font-size: 15px;
                }
            }

            :root {
                --primary-color: rgb(0, 115, 255);
                --primary-hover: rgb(30, 130, 255);
                --primary-glow: rgba(0, 115, 255, 0.4);
                --bg-color: #000000;
                --text-color: #ffffff;
                --text-secondary: rgba(255, 255, 255, 0.7);
                --border-color: rgba(40, 40, 40, 0.5);
                --glass-bg: rgba(26, 26, 26, 0.3);
                --card-bg: rgba(26, 26, 26, 0.3);
                --success-color: #10b981;
                --warning-color: #f59e0b;
            }

            .prompt-generator-page * {
                box-sizing: border-box;
            }

            .prompt-generator-page {
                color: var(--text-color);
                font-family:
                    "DM Sans",
                    "Inter",
                    -apple-system,
                    BlinkMacSystemFont,
                    "Segoe UI",
                    Roboto,
                    sans-serif;
                padding: 20px;
                margin: 0;
                display: flex;
                flex-direction: column;
            }

            .prompt-generator-page .page-header {
                text-align: center;
                margin-bottom: 30px;
                padding: 0 20px;
            }

            .prompt-generator-page .page-title {
                font-size: 1.8rem;
                font-weight: 700;
                color: white;
                margin-bottom: 8px;
                letter-spacing: -0.02em;
            }

            .prompt-generator-page .page-subtitle {
                font-size: 1rem;
                color: var(--text-secondary);
                margin: 0 0 16px 0;
            }

            /* Wizard Steps */
            .wizard-container {
                max-width: 1150px;
                margin: 0 auto;
                width: 100%;
            }

            .wizard-progress {
                display: flex;
                justify-content: center;
                gap: 8px;
                margin-bottom: 32px;
            }

            .wizard-step {
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .step-circle {
                width: 32px;
                height: 32px;
                border-radius: 50%;
                background: rgba(255, 255, 255, 0.1);
                border: 2px solid rgba(255, 255, 255, 0.2);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 14px;
                font-weight: 600;
                color: var(--text-secondary);
                transition: all 0.3s ease;
            }

            .step-circle.active {
                background: var(--primary-color);
                border-color: var(--primary-color);
                color: white;
            }

            .step-circle.completed {
                background: rgba(0, 115, 255, 0.3);
                border-color: rgba(0, 115, 255, 0.5);
                color: white;
            }

            .step-circle.clickable {
                cursor: pointer;
            }

            .step-circle.clickable:hover {
                transform: scale(1.05);
                box-shadow: 0 0 10px rgba(0, 115, 255, 0.3);
            }

            .step-label {
                font-size: 13px;
                color: var(--text-secondary);
                display: none;
            }

            .wizard-step.active .step-label {
                display: block;
                color: white;
            }

            .step-connector {
                width: 40px;
                height: 2px;
                background: rgba(255, 255, 255, 0.1);
            }

            .step-connector.completed {
                background: var(--success-color);
            }

            /* Step Panels */
            .step-panel {
                display: none;
                animation: fadeIn 0.3s ease;
            }

            .step-panel.active {
                display: block;
            }

            @keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(10px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            /* Input Card */
            .input-card {
                background: var(--glass-bg);
                backdrop-filter: blur(15px);
                border: 1px solid var(--border-color);
                border-radius: 16px;
                padding: 24px;
                margin-bottom: 20px;
            }

            .input-card h3 {
                font-size: 16px;
                font-weight: 600;
                margin: 0 0 16px 0;
                color: white;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .input-card h3 i {
                color: var(--primary-color);
                font-size: 18px;
            }

            .form-group {
                margin-bottom: 16px;
            }

            .form-group:last-child {
                margin-bottom: 0;
            }

            .form-label {
                display: block;
                font-size: 13px;
                font-weight: 500;
                color: var(--text-secondary);
                margin-bottom: 8px;
            }

            .form-input {
                width: 100%;
                padding: 12px 16px;
                background: rgba(0, 0, 0, 0.3);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 10px;
                color: white;
                font-size: 14px;
                font-family: inherit;
                transition: all 0.2s ease;
            }

            .form-input:focus {
                outline: none;
                border-color: var(--primary-color);
                box-shadow: 0 0 0 3px rgba(0, 115, 255, 0.1);
            }

            .form-input::placeholder {
                color: rgba(255, 255, 255, 0.3);
            }

            textarea.form-input {
                resize: vertical;
                min-height: 150px;
                line-height: 1.6;
            }

            .form-hint {
                font-size: 12px;
                color: var(--text-secondary);
                margin-top: 6px;
            }

            /* Buttons */
            .btn {
                padding: 12px 24px;
                border-radius: 10px;
                font-size: 14px;
                font-weight: 600;
                cursor: pointer;
                transition: all 0.2s ease;
                font-family: inherit;
                border: none;
                display: inline-flex;
                align-items: center;
                gap: 8px;
            }

            .btn-primary {
                background: linear-gradient(
                    135deg,
                    var(--primary-color),
                    #0066dd
                );
                color: white;
            }

            .btn-primary:hover:not(:disabled) {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(0, 115, 255, 0.4);
            }

            .btn-primary:disabled {
                opacity: 0.5;
                cursor: not-allowed;
            }

            .btn-secondary {
                background: rgba(255, 255, 255, 0.05);
                border: 1px solid rgba(255, 255, 255, 0.1);
                color: white;
            }

            .btn-secondary:hover {
                background: rgba(255, 255, 255, 0.1);
            }

            .btn-group {
                display: flex;
                gap: 12px;
                margin-top: 20px;
            }

            /* Loading Spinner */
            .loading-spinner {
                width: 20px;
                height: 20px;
                border: 2px solid rgba(255, 255, 255, 0.3);
                border-top-color: white;
                border-radius: 50%;
                animation: spin 0.8s linear infinite;
            }

            @keyframes spin {
                to {
                    transform: rotate(360deg);
                }
            }

            /* Style Selection */
            .style-options {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 12px;
                margin-bottom: 20px;
            }

            .style-option {
                background: rgba(0, 0, 0, 0.3);
                border: 2px solid rgba(255, 255, 255, 0.1);
                border-radius: 12px;
                padding: 16px;
                cursor: pointer;
                transition: all 0.2s ease;
                text-align: center;
            }

            .style-option:hover {
                border-color: rgba(255, 255, 255, 0.2);
            }

            .style-option.selected {
                border-color: var(--primary-color);
                background: rgba(0, 115, 255, 0.1);
            }

            .style-option i {
                font-size: 24px;
                margin-bottom: 8px;
                color: var(--primary-color);
            }

            .style-option .style-title {
                font-size: 14px;
                font-weight: 600;
                color: white;
                margin-bottom: 4px;
            }

            .style-option .style-desc {
                font-size: 12px;
                color: var(--text-secondary);
            }

            /* Scenes List */
            .scenes-list {
                display: flex;
                flex-direction: column;
                gap: 12px;
            }

            .scene-card {
                background: rgba(0, 0, 0, 0.3);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 12px;
                padding: 16px;
                transition: all 0.2s ease;
            }

            .scene-card:hover {
                border-color: rgba(255, 255, 255, 0.2);
            }

            .scene-header {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 12px;
            }

            .scene-number {
                width: 28px;
                height: 28px;
                background: var(--primary-color);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 12px;
                font-weight: 600;
                color: white;
                flex-shrink: 0;
            }

            .scene-title {
                font-size: 14px;
                font-weight: 500;
                color: white;
            }

            .scene-content {
                padding-left: 40px;
            }

            .scene-field {
                margin-bottom: 12px;
            }

            .scene-field:last-child {
                margin-bottom: 0;
            }

            .scene-field-label {
                font-size: 11px;
                font-weight: 600;
                color: var(--text-secondary);
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-bottom: 4px;
            }

            .scene-field-value {
                font-size: 13px;
                color: white;
                line-height: 1.5;
            }

            /* Prompt Cards */
            .prompt-card {
                background: rgba(0, 0, 0, 0.3);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 12px;
                padding: 16px;
                margin-bottom: 12px;
            }

            .prompt-card-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 12px;
            }

            .prompt-card-title {
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .prompt-text {
                background: rgba(0, 0, 0, 0.3);
                border: 1px solid rgba(255, 255, 255, 0.05);
                border-radius: 8px;
                padding: 12px;
                font-size: 13px;
                color: var(--text-secondary);
                line-height: 1.6;
            }

            /* Image Grid */
            .image-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
                gap: 16px;
                margin-top: 20px;
            }

            .image-card {
                background: var(--glass-bg);
                border: 1px solid var(--border-color);
                border-radius: 12px;
                overflow: hidden;
            }

            .image-card img {
                width: 100%;
                aspect-ratio: 9/16;
                object-fit: cover;
            }

            .image-card-footer {
                padding: 12px;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .image-card-label {
                font-size: 12px;
                color: var(--text-secondary);
            }

            /* Character Name Input */
            .character-input-group {
                display: flex;
                gap: 12px;
                align-items: flex-end;
            }

            .character-input-group .form-group {
                flex: 1;
                margin-bottom: 0;
            }

            /* Scene Cards Grid */
            .scene-cards-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
                gap: 16px;
                margin-top: 16px;
            }

            .scene-card-item {
                background: rgba(0, 0, 0, 0.3);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 12px;
                overflow: hidden;
                transition: all 0.2s ease;
                display: flex;
                flex-direction: column;
            }

            .scene-card-item:hover {
                border-color: rgba(255, 255, 255, 0.2);
            }

            .scene-card-image {
                aspect-ratio: 9/16;
                background: rgba(0, 0, 0, 0.3);
                display: flex;
                align-items: center;
                justify-content: center;
                position: relative;
            }

            .scene-card-image img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

            .scene-card-placeholder {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                padding: 20px;
                text-align: center;
                height: 100%;
            }

            .scene-card-placeholder i {
                font-size: 32px;
                color: rgba(255, 255, 255, 0.2);
                margin-bottom: 12px;
            }

            .scene-card-placeholder span {
                font-size: 12px;
                color: var(--text-secondary);
            }

            .scene-card-body {
                padding: 12px;
                display: flex;
                flex-direction: column;
                flex: 1;
            }

            .scene-card-header {
                display: flex;
                align-items: center;
                gap: 8px;
                margin-bottom: 8px;
            }

            .scene-card-number {
                width: 24px;
                height: 24px;
                background: var(--primary-color);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 11px;
                font-weight: 600;
                color: white;
                flex-shrink: 0;
            }

            .scene-card-title {
                font-size: 13px;
                font-weight: 600;
                color: white;
            }

            .scene-card-script {
                font-size: 12px;
                color: var(--text-secondary);
                line-height: 1.5;
                margin-bottom: 8px;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }

            .scene-card-prompt {
                font-size: 11px;
                color: rgba(255, 255, 255, 0.5);
                line-height: 1.5;
                margin-bottom: 12px;
                cursor: default;
                background: rgba(0, 0, 0, 0.2);
                border-radius: 8px;
                padding: 10px;
                border: 1px solid transparent;
            }

            .scene-card-prompt-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 6px;
                padding-bottom: 6px;
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            }

            .scene-card-prompt-label {
                font-size: 10px;
                color: rgba(255, 255, 255, 0.4);
                text-transform: uppercase;
                letter-spacing: 0.5px;
                font-weight: 500;
            }

            .scene-card-prompt-edit {
                font-size: 11px;
                color: rgba(255, 255, 255, 0.4);
                cursor: pointer;
            }
            .scene-card-prompt-edit i {
                font-size: 10px;
            }

            .scene-card-prompt-text {
                word-break: break-word;
                display: -webkit-box;
                -webkit-line-clamp: 5;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }

            /* Animation Cards Grid */
            .animation-cards-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
                gap: 16px;
                margin-top: 16px;
            }

            .animation-card-item {
                background: rgba(0, 0, 0, 0.3);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 12px;
                overflow: hidden;
                transition: all 0.2s ease;
                display: flex;
                flex-direction: column;
            }

            .animation-card-item:hover {
                border-color: rgba(255, 255, 255, 0.2);
            }

            .animation-card-media {
                display: flex;
                gap: 2px;
                background: rgba(0, 0, 0, 0.2);
            }

            .animation-card-source,
            .animation-card-video {
                flex: 1;
                aspect-ratio: 9/16;
                position: relative;
                display: flex;
                align-items: center;
                justify-content: center;
                background: rgba(0, 0, 0, 0.3);
            }

            .animation-card-source img,
            .animation-card-video video {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

            .animation-card-label {
                position: absolute;
                top: 8px;
                left: 8px;
                background: rgba(0, 0, 0, 0.7);
                padding: 4px 8px;
                border-radius: 4px;
                font-size: 10px;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                color: rgba(255, 255, 255, 0.8);
            }

            .animation-card-video-placeholder {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                text-align: center;
                padding: 20px;
                color: var(--text-secondary);
            }

            .animation-card-video-placeholder i {
                font-size: 32px;
                color: rgba(255, 255, 255, 0.15);
                margin-bottom: 8px;
            }

            .animation-card-video-placeholder span {
                font-size: 11px;
                color: rgba(255, 255, 255, 0.4);
            }

            .animation-card-item.generated {
                border-color: rgba(16, 185, 129, 0.3);
            }

            .animation-card-body {
                padding: 12px;
                flex: 1;
                display: flex;
                flex-direction: column;
            }

            .animation-card-actions {
                display: flex;
                gap: 8px;
                margin-top: auto;
                padding-top: 12px;
            }
            .animation-card-actions .btn {
                flex: 1;
            }

            .scene-card-download-btn {
                position: absolute;
                top: 8px;
                right: 8px;
                width: 28px;
                height: 28px;
                background: rgba(0, 0, 0, 0.7);
                border: 1px solid rgba(255, 255, 255, 0.2);
                border-radius: 6px;
                color: white;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 12px;
                transition: all 0.2s ease;
                z-index: 10;
                opacity: 0;
            }
            .animation-card-video:hover .scene-card-download-btn {
                opacity: 1;
            }
            .scene-card-download-btn:hover {
                background: rgba(99, 102, 241, 0.8);
                border-color: rgba(99, 102, 241, 0.8);
            }

            /* Per-card model picker in animation cards */
            .scene-card-model-picker {
                position: relative;
                width: 100%;
            }
            .scene-card-model-trigger {
                width: 100%;
